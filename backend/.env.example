# Copy to .env and adjust as needed.
NODE_ENV=development
PORT=5000

# Matches docker-compose.yml (service: db)
DATABASE_URL=postgresql://civicfix:civicfix@localhost:5433/civicfix

# Auth (Module 3)
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7

# Uploads (Module 4)
UPLOAD_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880

# CORS / rate limits
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_REPORTS_PER_HOUR=5
RATE_LIMIT_COMMENTS_PER_HOUR=20
