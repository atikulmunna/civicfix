# --- Local development ---
# Base URL of the CivicFix backend API (browser talks to it directly).
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# --- Production (Vercel) ---
# Use the same-origin API proxy instead (see next.config.ts):
#   NEXT_PUBLIC_API_URL=/api/v1
#   BACKEND_URL=https://your-backend.onrender.com
